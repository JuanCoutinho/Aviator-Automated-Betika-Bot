<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNIPER VIP | TERMINAL DE INTELIGÊNCIA</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800;900&family=JetBrains+Mono:wght@700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --green-neon: #10b981;
            --red-crash: #f43f5e;
            --aviator-blue: #3498db;
            --aviator-purple: #9b59b6;
            --aviator-pink: #e91e63;
            --bg-carbon: #050505;
            --panel-bg: rgba(15, 15, 15, 0.7);
            --glass-border: rgba(255, 255, 255, 0.05);
        }

        body {
            background-color: var(--bg-carbon);
            color: #ffffff;
            font-family: 'Inter', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        .font-mono { font-family: 'JetBrains Mono', monospace; }

        .glass-panel {
            background: var(--panel-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
        }

        /* Animação Radar */
        @keyframes pulseRadar {
            0% { transform: scale(0.8); opacity: 0.5; }
            100% { transform: scale(2.5); opacity: 0; }
        }

        .radar-ring {
            position: absolute;
            border-radius: 50%;
            border: 1px solid var(--green-neon);
            animation: pulseRadar 2s cubic-bezier(0.16, 1, 0.3, 1) infinite;
        }

        /* Botão Neon */
        .btn-green-neon {
            background: var(--green-neon);
            color: #000;
            box-shadow: 0 0 20px rgba(16, 185, 129, 0.3);
            transition: all 0.3s ease;
        }
        .btn-green-neon:hover {
            background: #0ea5e9;
            box-shadow: 0 0 30px rgba(14, 165, 233, 0.5);
            color: #fff;
        }

        /* Estilos das Velas */
        .vela-v { padding: 4px 8px; border-radius: 4px; border: 1px solid rgba(255,255,255,0.1); font-size: 12px; font-weight: bold; font-family: 'JetBrains Mono'; }
    </style>
</head>
<body class="selection:bg-emerald-500/30">

    <header class="relative min-h-[95vh] flex flex-col justify-center overflow-hidden px-4 md:px-8 pt-24 pb-16">
        <!-- Grid Background Tático -->
        <div class="absolute inset-0 z-0 opacity-10 pointer-events-none" 
             style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 40px 40px;">
        </div>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,#050505_80%)] z-0"></div>

        <div class="relative z-10 max-w-7xl mx-auto w-full grid lg:grid-cols-2 gap-16 items-center">
            
            <!-- LADO ESQUERDO: Texto de Conversão -->
            <div class="flex flex-col items-start text-left order-2 lg:order-1">
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md bg-emerald-500/10 border border-emerald-500/20 mb-6">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                    </span>
                    <span class="text-xs font-bold tracking-widest text-emerald-400 uppercase font-mono text-[10px]">API Conectada • Vagas 12/50</span>
                </div>

                <h1 class="text-5xl md:text-7xl font-black tracking-tighter text-white mb-6 leading-[0.95]">
                    O RADAR QUE <br/>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-cyan-500">
                        PREVÊ O CRASH.
                    </span>
                </h1>

                <p class="text-lg text-slate-400 max-w-xl mb-10 font-light leading-relaxed">
                    Transforme seu celular num terminal de operações. Algoritmo avançado conectado via <strong>WebSockets</strong> que lê os padrões milissegundos antes do avião decolar.
                </p>

                <button class="w-full sm:w-auto btn-green-neon px-10 py-5 rounded-lg text-lg font-black tracking-widest flex items-center justify-center gap-3 uppercase">
                    DESBLOQUEAR ACESSO VIP
                    <i data-lucide="crosshair"></i>
                </button>
            </div>

            <!-- LADO DIREITO: Mockup do Leitor (Ativo) -->
            <div class="order-1 lg:order-2 flex justify-center w-full relative">
                <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-3/4 h-3/4 bg-emerald-500/20 blur-[100px] rounded-full pointer-events-none"></div>
                
                <div class="glass-panel w-full max-w-md rounded-2xl border border-white/10 shadow-2xl overflow-hidden relative z-10">
                    <!-- Header do Bot -->
                    <div class="bg-white/5 px-6 py-4 border-b border-white/5 flex justify-between items-center">
                        <div class="flex items-center gap-2">
                            <i data-lucide="radar" class="w-5 h-5 text-emerald-500"></i>
                            <span class="font-mono font-bold text-sm text-slate-200 uppercase tracking-tighter">SNIPER_VIP_V2</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <div id="status-dot" class="w-2 h-2 rounded-full bg-slate-500"></div>
                            <span id="bot-status" class="font-mono text-[10px] text-slate-400 uppercase">ANALISANDO...</span>
                        </div>
                    </div>

                    <!-- Área do Multiplicador Principal -->
                    <div class="p-8 flex flex-col items-center justify-center min-h-[240px] relative">
                        
                        <!-- Radar Scanning -->
                        <div id="scanning-ui" class="relative flex items-center justify-center w-full h-full">
                            <div class="radar-ring w-32 h-32"></div>
                            <div class="radar-ring w-32 h-32" style="animation-delay: 1s"></div>
                            <i data-lucide="radar" class="w-12 h-12 text-emerald-500/50"></i>
                        </div>

                        <!-- Sinal Confirmado -->
                        <div id="signal-ui" class="hidden text-center">
                            <div class="inline-block px-4 py-1 mb-4 bg-emerald-500/20 border border-emerald-500/50 rounded text-emerald-400 font-mono font-bold text-sm">
                                ENTRADA CONFIRMADA
                            </div>
                            <div class="font-mono text-5xl font-black text-white mb-2">SAIR EM 1.50x</div>
                            <div class="text-slate-400 text-xs font-mono">Proteção no 2.00x</div>
                        </div>

                        <!-- Flying -->
                        <div id="flying-ui" class="hidden text-center w-full">
                            <div class="font-mono text-7xl font-black tracking-tighter text-white" id="current-mult">
                                1.00x
                            </div>
                        </div>
                    </div>

                    <!-- Histórico de Velas -->
                    <div class="bg-black/50 px-6 py-4 border-t border-white/5">
                        <div class="flex items-center gap-2 mb-3">
                            <i data-lucide="history" class="w-4 h-4 text-slate-500"></i>
                            <span class="text-xs uppercase tracking-widest text-slate-500 font-bold">Últimos Padrões</span>
                        </div>
                        <div id="history-list" class="flex gap-2 overflow-hidden">
                            <!-- Injetado via JS -->
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </header>

    <!-- Recursos Técnicos -->
    <section class="max-w-7xl mx-auto px-6 py-24 border-t border-white/5">
        <div class="grid md:grid-cols-3 gap-6">
            <div class="glass-panel p-8 rounded-xl flex flex-col items-start border-l-4 border-l-emerald-500">
                <i data-lucide="zap" class="w-8 h-8 text-emerald-500 mb-6"></i>
                <h4 class="text-xl font-bold text-white mb-3 uppercase tracking-tight">Latência Zero</h4>
                <p class="text-sm text-slate-400 font-light leading-relaxed">Nossos servidores interceptam o sinal no exato milissegundo. Sem delay de Telegram ou WhatsApp.</p>
            </div>
            <div class="glass-panel p-8 rounded-xl flex flex-col items-start border-l-4 border-l-cyan-500">
                <i data-lucide="crosshair" class="w-8 h-8 text-cyan-500 mb-6"></i>
                <h4 class="text-xl font-bold text-white mb-3 uppercase tracking-tight">Sniper de Velas</h4>
                <p class="text-sm text-slate-400 font-light leading-relaxed">O algoritmo identifica a saturação de velas azuis e alerta o momento exato para buscar multiplicadores altos.</p>
            </div>
            <div class="glass-panel p-8 rounded-xl flex flex-col items-start border-l-4 border-l-purple-500">
                <i data-lucide="activity" class="w-8 h-8 text-purple-500 mb-6"></i>
                <h4 class="text-xl font-bold text-white mb-3 uppercase tracking-tight">Gestão Inteligente</h4>
                <p class="text-sm text-slate-400 font-light leading-relaxed">Cálculo integrado que indica exatamente quanto cobrir na próxima entrada para lucro garantido.</p>
            </div>
        </div>
    </section>

    <footer class="bg-[#020202] py-12 px-6 border-t border-white/5">
        <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-start gap-8">
            <h2 class="text-xl font-black tracking-tighter text-white uppercase flex items-center gap-2">
                <i data-lucide="radar" class="w-6 h-6 text-emerald-500"></i> AVIATOR_SNIPER
            </h2>
            <p class="text-slate-600 text-xs font-mono">© 2026 TERMINAL DE ELITE. TODOS OS DIREITOS RESERVADOS.</p>
        </div>
    </footer>

    <script>
        lucide.createIcons();
        const socket = io();
        
        const scanUI = document.getElementById('scanning-ui');
        const signalUI = document.getElementById('signal-ui');
        const flyingUI = document.getElementById('flying-ui');
        const multVal = document.getElementById('current-mult');
        const historyList = document.getElementById('history-list');
        const botStatus = document.getElementById('bot-status');
        const statusDot = document.getElementById('status-dot');

        socket.on('game_update', (data) => {
            if (data.multiplier > 1.00 && data.multiplier < 1.05 && data.canBet) {
                scanUI.classList.add('hidden');
                signalUI.classList.remove('hidden');
                flyingUI.classList.add('hidden');
                botStatus.innerText = 'SINAL ENCONTRADO';
                statusDot.className = 'w-2 h-2 rounded-full bg-emerald-500 animate-pulse';
            } else if (data.multiplier >= 1.05) {
                scanUI.classList.add('hidden');
                signalUI.classList.add('hidden');
                flyingUI.classList.remove('hidden');
                multVal.innerText = data.multiplier.toFixed(2) + 'x';
                
                // Cores padrão Aviator no texto
                if (data.multiplier < 2) multVal.className = 'font-mono text-7xl font-black tracking-tighter text-white';
                else if (data.multiplier < 10) multVal.className = 'font-mono text-7xl font-black tracking-tighter text-[#9b59b6]';
                else multVal.className = 'font-mono text-7xl font-black tracking-tighter text-[#e91e63]';

                botStatus.innerText = 'LIVE_TRACKING';
                statusDot.className = 'w-2 h-2 rounded-full bg-cyan-500';
            } else {
                scanUI.classList.remove('hidden');
                signalUI.classList.add('hidden');
                flyingUI.classList.add('hidden');
                botStatus.innerText = 'ANALISANDO...';
                statusDot.className = 'w-2 h-2 rounded-full bg-slate-500';
            }

            if (data.history) {
                historyList.innerHTML = '';
                data.history.forEach(v => {
                    let color = 'text-[#3498db] border-[#3498db]/30 bg-[#3498db]/10';
                    if (v >= 2) color = 'text-[#9b59b6] border-[#9b59b6]/30 bg-[#9b59b6]/10';
                    if (v >= 10) color = 'text-[#e91e63] border-[#e91e63]/30 bg-[#e91e63]/10';
                    historyList.innerHTML += `<div class="vela-v ${color}">${v.toFixed(2)}x</div>`;
                });
            }
        });
    </script>
</body>
</html>